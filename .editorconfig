# EditorConfig — keep coding style consistent across editors and OSes
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = unset

[*.{kt,kts}]
indent_size = 4
max_line_length = 120

[*.{java,scala,groovy}]
indent_size = 4
max_line_length = 120

[*.{ets,ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 100
quote_type = single

[*.{json,json5,yaml,yml,toml}]
indent_size = 2

[*.{xml,html}]
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{md,markdown}]
# Keep markdown flexible
indent_size = unset
